# Copy this file to .env and edit as needed.
#   cp .env.example .env

# ---- CARLA server ----
CARLA_VERSION=0.9.15
CARLA_HOST=localhost          # Set to Linux server IP when connecting remotely
CARLA_PORT=2000
CARLA_QUALITY=Epic            # Low / Medium / High / Epic

# ---- Dataset scale ----
NUM_TRAIN=10000
NUM_TEST=2000
NUM_VERSIONS=10

# ---- Which phase to run (1 / 2 / 3 / all) ----
RUN_PHASE=all

# ---- Remote server (for make sync) ----
REMOTE_USER=ubuntu
REMOTE_HOST=
REMOTE_DIR=~/Carla
